<group name="caddy,web,accesslog">

  <!-- Base rule: Match Caddy access logs parsed by the built-in JSON decoder -->
  <rule id="100300" level="0">
    <decoded_as>json</decoded_as>
    <field name="logger">http.log.access</field>
    <description>Caddy access log messages grouped.</description>
    <group>web,accesslog</group>
  </rule>

  <!-- WordPress scanning detection - BLOCK (level 12 triggers active response) -->
  <rule id="100307" level="12">
    <if_sid>100300</if_sid>
    <field name="request.uri">wp-|wp/|/wp</field>
    <description>Caddy: WordPress scanning detected ($(request.method) $(request.uri)) from $(request.remote_ip) - Blocked.</description>
    <group>attack,web_scan,pci_dss_11.4</group>
  </rule>

  <rule id="100301" level="3">
    <if_sid>100300</if_sid>
    <status>^2|^3</status>
    <description>Caddy: Successful or redirect HTTP request ($(request.method) $(request.uri)).</description>
  </rule>

  <rule id="100302" level="5">
    <if_sid>100300</if_sid>
    <status>^4</status>
    <description>Caddy: Client error request ($(request.method) $(request.uri) returned $(status)).</description>
    <group>web_error</group>
  </rule>

  <rule id="100303" level="7">
    <if_sid>100302</if_sid>
    <status>^401$|^403$</status>
    <description>Caddy: Unauthorized or Forbidden access attempt to $(request.uri) from $(request.remote_ip).</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5</group>
  </rule>

  <rule id="100304" level="7">
    <if_sid>100300</if_sid>
    <status>^5</status>
    <description>Caddy: Server error response ($(request.method) $(request.uri) returned $(status)).</description>
    <group>service_availability</group>
  </rule>

  <rule id="100305" level="10" frequency="15" timeframe="10">
    <if_matched_sid>100302</if_matched_sid>
    <same_field>request.remote_ip</same_field>
    <description>Caddy: Multiple client errors (4xx) from same source IP - Possible Web Scanning.</description>
    <group>reconnaissance,pci_dss_11.4</group>
  </rule>

  <rule id="100306" level="11" frequency="10" timeframe="20">
    <if_matched_sid>100303</if_matched_sid>
    <same_field>request.remote_ip</same_field>
    <description>Caddy: Multiple Unauthorized/Forbidden attempts - Possible Brute Force.</description>
    <group>attack,pci_dss_11.4</group>
  </rule>

</group>